function espRenderAll(cid){
  var esps=expositors.filter(function(e){return e.cid===cid;});
  var tot=esps.reduce(function(s,e){return s+(e.samples||[]).length;},0);
  var types=lsGetTypes();
  var h='<div class="inv-toolbar">';
  h+='<button class="btn-add-esp" onclick="espAddNew(\''+cid+'\')">+ Nuovo espositore</button>';
  // Merch dropdown (only if custom types exist)
  if(types.length){
    h+='<div class="merch-drop">';
    h+='<button class="btn-add-esp" style="background:#5C5145;position:relative;padding-right:26px" onclick="toggleMerch(\''+cid+'\')">Merch <span style="position:absolute;right:9px;top:50%;transform:translateY(-50%);font-size:9px">&#9660;</span></button>';
    h+='<div class="merch-menu" id="merch-'+cid+'">';
    types.forEach(function(t){
      var icon=t.shape==='rot'?'&#127991;':'&#128366;';
      var sub=(t.total||0)+' slot'+(t.shape==='rot'?' · '+t.perSide+'/lato':'')+(t.shape==='rot'?' Girevole':' Lineare');
      h+='<div class="merch-item" onclick="espFromType(\''+cid+'\',\''+t.id+'\')">'
        +'<div class="merch-item-name">'+icon+' '+x(t.name)+'</div>'
        +'<div class="merch-item-sub">'+sub+'</div>'
        +'</div>';
    });
    h+='<div class="merch-manage" onclick="openSettings()">&#9881; Gestisci tipi</div>';
    h+='</div></div>';
  }
  if(tot>0) h+='<span style="font-size:11px;color:#888">'+tot+' campioni · '+esps.length+' espositori</span>';
  h+='</div>';
  if(!esps.length){
    h+='<div class="inv-empty"><div class="ie">&#127991;&#65039;</div><p>Nessun espositore</p>'
      +'<span>Crea il primo con "+ Nuovo espositore"'+(types.length?' o dal menu Merch':' (o crea tipi da ⚙ Impostazioni)')+'.</span></div>';
  } else {
    esps.sort(function(a,b){return (a.name||'').localeCompare(b.name||'','it',{sensitivity:'base'});});
    esps.forEach(function(e){ h+=espRenderCard(cid,e); });
  }
  return h;
}

