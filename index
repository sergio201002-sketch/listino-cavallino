function _isMeasure(sz){ return /^\d[\d.]*\s*[Xx]\s*\d/.test(sz); }

function rebuildSizeOpts(arr, keepVal){
  if(keepVal === undefined) keepVal = _szFilter;
  var regular = arr.filter(function(v){ return _isMeasure(v); });
  var speciale = arr.filter(function(v){ return !_isMeasure(v); });
  // Check if kept value still valid
  if(keepVal && arr.indexOf(keepVal)<0) keepVal = '';
  _szFilter = keepVal;
  var label = keepVal || 'Tutti i formati';
  document.getElementById('sz-label').textContent = label;
  // Regular options
  var regEl = document.getElementById('sz-regular');
  regEl.innerHTML = regular.map(function(v){
    return '<div class="cdp-opt'+(v===keepVal?' active':'')+'" onclick="setSzFilter(\''+v+'\',\''+v+'\')">'+x(v)+'</div>';
  }).join('');
  // Speciale group
  var spWrap = document.getElementById('sz-speciale-wrap');
  var spEl = document.getElementById('sz-speciale');
  var spCount = document.getElementById('sz-sp-count');
  if(speciale.length){
    spWrap.style.display='';
    spCount.textContent = speciale.length;
    spEl.innerHTML = speciale.map(function(v){
      return '<div class="cdp-opt'+(v===keepVal?' active':'')+'" onclick="setSzFilter(\''+v+'\',\''+v+'\')">'+x(v)+'</div>';
    }).join('');
    // Auto-open group if selected value is a speciale
    if(keepVal && !_isMeasure(keepVal)){
      spEl.style.display='';
      document.getElementById('sz-sp-arrow').textContent='▾';
      _szSpOpen=true;
    } else if(!_szSpOpen){
      spEl.style.display='none';
      document.getElementById('sz-sp-arrow').textContent='▶';
    }
  } else {
    spWrap.style.display='none';
  }
  // Update placeholder active state
  var ph = document.querySelector('#sz-panel .cdp-placeholder');
  if(ph) ph.className='cdp-opt cdp-placeholder'+(keepVal?'':' active');
}

function setSzFilter(val, label){
