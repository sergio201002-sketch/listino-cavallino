// === STATI CAMPIONI ===
var _STATI = [
  {id:'presente', label:'Presente',    dot:'#2e7d32', cls:'cs-presente st-presente'},
  {id:'ordinato', label:'Ordinato',    dot:'#1565c0', cls:'cs-ordinato st-ordinato'},
  {id:'cambiare', label:'Da cambiare', dot:'#e65100', cls:'cs-cambiare st-cambiare'},
  {id:'smontare', label:'Da smontare', dot:'#b71c1c', cls:'cs-smontare st-smontare'},
];
function espStatInfo(status){
  for(var i=0;i<_STATI.length;i++){if(_STATI[i].id===status) return _STATI[i];}
  return {id:'presente',label:'Presente',dot:'#2e7d32',cls:'cs-presente st-presente'};
}
function espRotTotal(e){ return e.total || 16; }
function espRotPerSide(e){ return e.perSide || 8; }

function espCountLabel(e){
  if(e.shape==='rot'){ return e.samples.length+'/'+(espRotTotal(e))+' slot'; }
  return e.samples.length+' campioni';
}

function espPickSlot(eid, slotIdx){
  window._espSlotPending = {eid:eid, slot:parseInt(slotIdx,10)};
  var card=document.getElementById('esp-'+eid);
  if(card){
    card.querySelectorAll('.esp-rot-slot').forEach(function(sl){sl.classList.remove('esp-rot-slot-active');});
    var sl=card.querySelector('[data-slot="'+slotIdx+'"]');
    if(sl) sl.classList.add('esp-rot-slot-active');
  }
  var inp=document.getElementById('esrs-'+eid);
  if(inp) inp.focus();
}

function espRemSlot(eid, slotIdx){
  var e=expositors.find(function(x){return x.id===eid;}); if(!e) return;
  e.samples=e.samples.filter(function(s){return s.slot!==parseInt(slotIdx,10);});
  lsSave(); espRefreshPane(e.cid);
}

function espSetSlotStatus(eid, slotIdx, status){
  var e=expositors.find(function(x){return x.id===eid;}); if(!e) return;
  var s=e.samples.find(function(x){return x.slot===parseInt(slotIdx,10);}); if(!s) return;
  s.status=status; lsSave(); espRefreshPane(e.cid);
}

function espOpenSlotMenu(btn, eid, slotIdx){
  var existing=document.getElementById('slot-status-menu');
  if(existing) existing.parentNode.removeChild(existing);
  var menu=document.createElement('div');
  menu.id='slot-status-menu'; menu.className='slot-status-menu';
  _STATI.forEach(function(st){
    var item=document.createElement('div');
    item.className='ssm-item';
    var dot=document.createElement('span'); dot.className='ssm-dot'; dot.style.background=st.dot;
    var lbl=document.createTextNode(st.label);
    item.appendChild(dot); item.appendChild(lbl);
    item.onclick=function(ev){
      ev.stopPropagation();
      espSetSlotStatus(eid,slotIdx,st.id);
      if(menu.parentNode) menu.parentNode.removeChild(menu);
    };
    menu.appendChild(item);
  });
  var r=btn.getBoundingClientRect();
  menu.style.top=(r.bottom+3)+'px';
  menu.style.left=Math.max(5,r.left-110)+'px';
  document.body.appendChild(menu);
  setTimeout(function(){
    document.addEventListener('click',function close(){if(menu.parentNode)menu.parentNode.removeChild(menu);document.removeEventListener('click',close);},{once:true});
  },10);
}

function espSetRotView(eid, mode){
  var e=expositors.find(function(x){return x.id===eid;}); if(!e) return;
  e.viewMode=mode; lsSave(); espRefreshPane(e.cid);
}

function espRenderRotGrid(cid, e){
  var view=e.viewMode||'full';
  var perSide=espRotPerSide(e);
  var total=espRotTotal(e);
  var hasSides=perSide&&perSide>0&&perSide*2<=total+1;
  var h='';
  if(hasSides){
    h+='<div class="esp-rot-tabs">';
    h+='<button class="esp-rot-tab'+(view==='right'?' active':'')+'" onclick="espSetRotView(\''+e.id+'\',\'right\')">Lato destro ('+perSide+')</button>';
    h+='<button class="esp-rot-tab'+(view==='left'?' active':'')+'" onclick="espSetRotView(\''+e.id+'\',\'left\')">Lato sinistro ('+perSide+')</button>';
    h+='<button class="esp-rot-tab'+(view==='full'?' active':'')+'" onclick="espSetRotView(\''+e.id+'\',\'full\')">Tutto ('+total+')</button>';
    h+='</div>';
  }
  var startSlot,endSlot,showBoth;
  if(!hasSides){startSlot=0;endSlot=total-1;showBoth=false;}
  else if(view==='right'){startSlot=0;endSlot=perSide-1;showBoth=false;}
  else if(view==='left'){startSlot=perSide;endSlot=total-1;showBoth=false;}
  else{startSlot=0;endSlot=total-1;showBoth=true;}
  function slotHtml(idx){
    var item=e.samples.find(function(x){return x.slot===idx;});
    var num=idx+1;
    if(item){
      var si=espStatInfo(item.status||'presente');
      // Extract st-* class only
      var stCls=si.cls.split(' ').filter(function(c){return c.indexOf('st-')===0;}).join(' ');
      return '<div class="esp-rot-slot filled '+stCls+'" data-slot="'+idx+'">'
        +'<div class="esp-rot-slot-num">#'+num+'</div>'
        +'<button class="esp-rot-slot-sbtn" style="--st-dot:'+si.dot+'" onclick="event.stopPropagation();espOpenSlotMenu(this,\''+e.id+'\','+idx+')" title="'+si.label+'"></button>'
        +'<div class="esp-rot-slot-series">'+x(item.s.substring(0,14))+'</div>'
        +'<div class="esp-rot-slot-color">'+x(item.c)+'</div>'
        +'<div class="esp-rot-slot-sz">'+x(item.z)+(item.f?' · '+x(item.f):'')+'</div>'
        +'<button class="esp-rot-slot-del" onclick="event.stopPropagation();espRemSlot(\''+e.id+'\','+idx+')" title="Rimuovi">&#10005;</button>'
        +'</div>';
    }
    return '<div class="esp-rot-slot empty" data-slot="'+idx+'" onclick="espPickSlot(\''+e.id+'\','+idx+')">'
      +'<div class="esp-rot-slot-num">#'+num+'</div>'
      +'<div class="esp-rot-slot-add">+</div>'
      +'<div class="esp-rot-slot-hint">Clicca</div>'
      +'</div>';
  }
  var gridCls='esp-rot-grid'+(perSide===5?' g5':'');
  h+='<div class="esp-rot-grid-wrap">';
  if(showBoth){
    h+='<div class="esp-rot-side"><div class="esp-rot-side-lbl">Lato destro</div><div class="'+gridCls+'">';
    for(var i=0;i<perSide;i++) h+=slotHtml(i);
    h+='</div></div>';
    h+='<div class="esp-rot-side"><div class="esp-rot-side-lbl">Lato sinistro</div><div class="'+gridCls+'">';
    for(var j=perSide;j<total;j++) h+=slotHtml(j);
    h+='</div></div>';
  } else {
    h+='<div class="esp-rot-side"><div class="'+gridCls+'">';
    for(var k=startSlot;k<=endSlot;k++) h+=slotHtml(k);
    h+='</div></div>';
  }
  h+='</div>';
  return h;
}

function espAddCamp(eid, pid){
  var e=expositors.find(function(x){return x.id===eid;}); if(!e) return;
  if(!e.samples) e.samples=[];
  var p=PRODUCTS.find(function(x){return x.id===pid;}); if(!p) return;

  if(e.shape==='rot'){
    var total=espRotTotal(e);
    var pending=window._espSlotPending;
    var slotIdx=-1;
    if(pending&&pending.eid===eid){
      slotIdx=pending.slot; window._espSlotPending=null;
    } else {
      var used={};
      e.samples.forEach(function(s){if(typeof s.slot!=='undefined') used[s.slot]=1;});
      for(var i=0;i<total;i++){if(!used[i]){slotIdx=i;break;}}
    }
    if(slotIdx<0){toast('Tutti gli slot sono occupati');return;}
    e.samples=e.samples.filter(function(s){return s.slot!==slotIdx;});
    e.samples.push({slot:slotIdx,id:p.id,s:p.s,c:p.c,z:p.z,f:p.f,status:'presente'});
    lsSave(); espRefreshPane(e.cid);
    toast('Slot #'+(slotIdx+1)+' aggiornato');
    return;
  }

  if(e.samples.find(function(s){return s.id===pid;})){ toast('Gia\' presente'); return; }
  e.samples.push({id:p.id,s:p.s,c:p.c,z:p.z,f:p.f,status:'presente'});
  lsSave();
  var cnt=document.getElementById('espc-'+eid);
  if(cnt) cnt.textContent=espCountLabel(e);
  var items=document.getElementById('esrci-'+eid);
  if(items) items.innerHTML=espRenderCamps(e);
  var inp=document.getElementById('esrs-'+eid);
  if(inp){inp.value=''; var rr=document.getElementById('esrr-'+eid); if(rr){rr.classList.remove('vis');rr.innerHTML='';}}
  toast('Campione aggiunto');
}

function espDelCamp(eid, pid){
  var e=expositors.find(function(x){return x.id===eid;}); if(!e) return;
  e.samples=e.samples.filter(function(s){return s.id!==pid;});
  lsSave();
  if(e.shape==='rot'){espRefreshPane(e.cid);return;}
  var cnt=document.getElementById('espc-'+eid);
  if(cnt) cnt.textContent=espCountLabel(e);
  var items=document.getElementById('esrci-'+eid);
  if(items) items.innerHTML=espRenderCamps(e);
}

function espToggleCampStatus(eid, sid, btn){
  var e=expositors.find(function(x){return x.id===eid;}); if(!e) return;
  var s=e.samples.find(function(x){return x.id===sid;}); if(!s) return;
  var cur=s.status||'presente';
  var idx=0;
  for(var i=0;i<_STATI.length;i++){if(_STATI[i].id===cur){idx=i;break;}}
  idx=(idx+1)%_STATI.length;
  s.status=_STATI[idx].id; lsSave();
  var si=espStatInfo(s.status);
  var csCls=si.cls.split(' ').filter(function(c){return c.indexOf('cs-')===0;}).join(' ');
  btn.className='camp-status-btn '+csCls;
  btn.textContent=si.label;
}

function espSaveNote(eid, val){
  var e=expositors.find(function(x){return x.id===eid;}); if(!e) return;
  e.notes=val; lsSave();
}

function espRenderCamps(e){
  if(!e.samples||!e.samples.length) return '<div class="no-camp">Nessun campione. Cerca un prodotto sopra.</div>';
  return e.samples.map(function(s){
    var si=espStatInfo(s.status||'presente');
    var csCls=si.cls.split(' ').filter(function(c){return c.indexOf('cs-')===0;}).join(' ');
    return '<div class="camp-row">'
      +'<span class="camp-badge">'+x(s.s.substring(0,6))+'</span>'
      +'<div class="camp-info"><div class="camp-name">'+x(s.s)+' — '+x(s.c)+'</div>'
      +'<div class="camp-detail">'+x(s.z)+' · '+x(s.f)+'</div></div>'
      +'<button class="camp-status-btn '+csCls+'" onclick="espToggleCampStatus(\''+e.id+'\',\''+s.id+'\',this)">'+si.label+'</button>'
      +'<button class="camp-del" onclick="espDelCamp(\''+e.id+'\',\''+s.id+'\')">&#10005;</button>'
      +'</div>';
  }).join('');
}

function espRenderCard(cid, e){
  var cl=e.collapsed?' collapsed':'';
  var h='<div class="esp-card'+cl+'" id="esp-'+e.id+'">';
  h+='<div class="esp-header" onclick="espToggle(\''+e.id+'\')">';
