// === LOGO MANAGEMENT ===
(function(){
  var inp = document.createElement('input');
  inp.type='file'; inp.id='logo-file-inp'; inp.accept='image/*';
  inp.style.display='none';
  inp.onchange = function(){
    var file = inp.files[0]; if(!file) return;
    var reader = new FileReader();
    reader.onload = function(e){
      var data = e.target.result;
      try{ localStorage.setItem('cc_logo', data); }catch(ex){}
      logoApply(data);
    };
    reader.readAsDataURL(file);
    inp.value='';
  };
  document.body.appendChild(inp);
  var saved = localStorage.getItem('cc_logo');
  if(saved) logoApply(saved);
})();
function logoApply(src){
  var img = document.getElementById('logo-img');
  var ph  = document.getElementById('logo-placeholder');
  var prev= document.getElementById('sett-logo-preview');
  if(src){
    img.src=src; img.style.display='block';
    if(ph) ph.style.display='none';
