// Save order
function saveOrder(){
  if(!cart.length){ toast('Carrello vuoto'); return; }
  var cl=clients.find(function(c){return c.id===_cartClientId;});
  var cid=cl?cl.id:''; var cn=cl?cl.name:(_cartRef||'Senza cliente');
