    return '<div class="ci'+(hasDisc?' has-disc':'')+'" id="ci-'+item.id+'">'
      +'<div class="ci-top">'
      +'<div class="ci-code">'+x(item.s.substring(0,8))+'</div>'
      +'<div class="ci-head-info"><div class="ci-series">'+x(item.s)+'<span id="ci-disc-badge-'+item.id+'">'+discBadge+'</span></div>'
