});

// Testo ordine
function _buildOrderText(){
  var cliName='';
  var cl=clients.find(function(c){return c.id===_cartClientId;}); if(cl) cliName=cl.name;
  var lines=[];
  var rec=_orderRecipient&&_orderRecipient.trim();
  if(rec){ lines.push('Buongiorno '+rec); lines.push(''); }
  var headline='Ordinare';
  if(cliName) headline+=' x '+cliName;
  if(_cartRef&&_cartRef.trim()) headline+=' con riferimento '+_cartRef.trim();
  headline+=' :';
  lines.push(headline); lines.push('');
  cart.forEach(function(item){
    var parts=[item.s,item.c,item.z,item.f].filter(Boolean);
    var qty=(parseFloat(item.mq)||0).toFixed(2).replace('.',',')+' mq';
    lines.push(parts.join(' ')+' - '+qty);
  });
  lines.push(''); lines.push('Grazie, saluti');
  return lines.join('\n');
}

function _renderCartOutput(){
  var out=document.getElementById('cp-output');
  if(out) out.textContent=cart.length?_buildOrderText():'';
  var recPrev=document.getElementById('cp-rec-preview');
  if(recPrev) recPrev.textContent=(_orderRecipient&&_orderRecipient.trim())?_orderRecipient.trim():'— nessuno';
  var prevInfo=document.getElementById('cp-prev-info');
  if(prevInfo) prevInfo.textContent=cart.length?(cart.length+' articol'+(cart.length===1?'o':'i')):'—';
}

