function espFromType(cid, tid){
  var types = lsGetTypes();
  var t = types.find(function(x){return x.id===tid;});
  if(!t){ toast('Tipo non trovato'); return; }
  var n = expositors.filter(function(e){return e.cid===cid;}).length+1;
  var ne = {id:'e'+Date.now(), cid:cid, name:t.name+' '+n, shape:t.shape, total:t.total, perSide:t.perSide, samples:[], notes:'', collapsed:false};
  expositors.push(ne); lsSave();
  espRefreshPane(cid);
  document.querySelectorAll('.merch-menu.open').forEach(function(m){ m.classList.remove('open'); });
}

// === SORT ORDER ===

// Sort order: 0=fondo, 1=c2o, 2=chevron/millerig, 3=speciale
function groupOrder(p){
  if(!p.v) return p.t==='speciale' ? 5 : 0;
  if(p.v==='soft'||p.v==='mr'||p.v==='vc'||p.v==='relievo'||p.v==='intreccio') return 1;
  if(p.v==='vc_mr') return 2;
  if(p.v==='c2o'||p.v==='vc_c2o'||p.v==='intreccio_c2o') return 3;
  if(p.v==='chevron'||p.v==='millerig') return 4;
  return 1;
}
// Pre-sort all products: by series → group order → color
PRODUCTS.sort(function(a,b){
  if(a.s<b.s) return -1; if(a.s>b.s) return 1;
  var ga=groupOrder(a), gb=groupOrder(b);
  if(ga!==gb) return ga-gb;
  if(a.z<b.z) return -1; if(a.z>b.z) return 1;
  if(a.c<b.c) return -1; if(a.c>b.c) return 1;
  return 0;
});

// INIT
rebuildSizeOpts(sizes);
updateBadge();
applyFilter();
