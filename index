    h+='<input class="esp-search-input" id="esrs-'+e.id+'" placeholder="Cerca serie, colore, formato..." oninput="espSearch(\''+e.id+'\',this.value)">';
    h+='<div class="esp-search-results" id="esrr-'+e.id+'"></div>';
    h+='</div>';
    h+='<div class="camp-items" id="esrci-'+e.id+'">'+espRenderCamps(e)+'</div>';
  }
  h+='<textarea class="camp-note" placeholder="Note espositore..." onchange="espSaveNote(\''+e.id+'\',this.value)">'+x(e.notes||'')+'</textarea>';
