}

function _updateCartFooter(){
  var totMq=cart.reduce(function(s,i){return s+(parseFloat(i.mq)||0);},0);
  var totVal=cart.reduce(function(s,i){return s+_cartItemTot(i);},0);
  var mqEl=document.getElementById('cp-tot-mq'); if(mqEl) mqEl.textContent=totMq.toFixed(2)+' mq';
  var valEl=document.getElementById('cp-tot-val'); if(valEl) valEl.textContent=fmtE(totVal);
  var sumEl=document.getElementById('cp-fold-sum'); if(sumEl) sumEl.textContent=totMq.toFixed(2)+' mq · '+fmtE(totVal);
}

function _updateCartItemRow(pid){
  var item=cart.find(function(c){return c.id===pid;}); if(!item) return;
  var mq=parseFloat(item.mq)||0;
  var d=item.discount||{type:'none'};
  var dType=d.type||'none';
  var baseUnit=item.p||0;
  var finalUnit=_cartItemUnit(item);
  var finalTot=_cartItemTot(item);
  var hasDisc=(dType==='pct5'||dType==='pct10'||(dType==='custom'&&d.customPrice!==null)||(dType==='std'&&d.std&&d.std.length));
  var noPriceYet=(dType==='custom'&&d.customPrice===null);
  var totEl=document.getElementById('ci-tot-'+pid); if(totEl){totEl.textContent=noPriceYet?'€ —':fmtE(finalTot); totEl.className='ci-tot'+(noPriceYet?' no-price':'');}
  var baseEl=document.getElementById('ci-base-'+pid); if(baseEl){baseEl.textContent=fmtE(baseUnit)+'/m²'; baseEl.className='ci-price-val'+(hasDisc&&!noPriceYet?' strike':'');}
  var finalEl=document.getElementById('ci-final-'+pid); if(finalEl){finalEl.textContent=noPriceYet?'—':fmtE(finalUnit)+'/m²'; finalEl.className='ci-price-val'+(hasDisc&&!noPriceYet?' discounted':'');}
  var finalRow=document.getElementById('ci-final-row-'+pid); if(finalRow) finalRow.style.display=hasDisc?'flex':'none';
  var badgeEl=document.getElementById('ci-disc-badge-'+pid);
  if(badgeEl){
    var badge='';
    if(dType==='pct5') badge='<span class="ci-disc-badge">&#8722;5%</span>';
    if(dType==='pct10') badge='<span class="ci-disc-badge">&#8722;10%</span>';
    if(dType==='custom'&&d.customPrice!==null) badge='<span class="ci-disc-badge custom">'+fmtE(d.customPrice)+'/m²</span>';
    if(dType==='std'&&d.std&&d.std.length) badge='<span class="ci-disc-badge std">'+d.std.map(function(v){return '&#8722;'+v+'%';}).join(' ')+'</span>';
    badgeEl.innerHTML=badge;
  }
  // Bancali
  var balEl=document.getElementById('ci-bal-'+pid);
  if(balEl&&item.m){
    var bancali=mq/item.m;
    var isEsatto=Math.abs(bancali-Math.round(bancali))<0.01;
    balEl.className='ci-bancali'+(isEsatto?' ok':'');
    var bMain=document.getElementById('ci-bal-main-'+pid);
    if(bMain) bMain.textContent='📦 '+bancali.toFixed(2)+' bancal'+(bancali<=1?'e':'i')+(isEsatto?' ✅':'');
  }
  _updateCartFooter();
  _renderCartOutput();
}

function setCartItemMq(pid,val){
  var mq=parseFloat(val);
  var item=cart.find(function(c){return c.id===pid;});
  if(item&&mq>0){ item.mq=mq; lsSave(); _updateCartItemRow(pid); }
}

function setCartItemDiscType(pid,type){
  var item=cart.find(function(c){return c.id===pid;}); if(!item) return;
  if(!item.discount) item.discount={type:'none',customPrice:null,std:[]};
  item.discount.type=type;
  if(type!=='custom') item.discount.customPrice=null;
  if(type==='std'&&(!item.discount.std||!item.discount.std.length)){
    var mq=parseFloat(item.mq)||0;
    item.discount.std=(item.m&&mq>=item.m)?[60,10,10]:[60,10,5];
  }
  lsSave(); updateCartUI();
}

function setCartItemStd(pid,idx,val){
  var item=cart.find(function(c){return c.id===pid;}); if(!item) return;
  if(!item.discount) item.discount={type:'std',customPrice:null,std:[]};
  if(!item.discount.std) item.discount.std=[];
  item.discount.std[idx]=parseFloat(val)||0;
  lsSave(); _updateCartItemRow(pid);
}

function addCartStdStep(pid){
  var item=cart.find(function(c){return c.id===pid;}); if(!item) return;
  if(!item.discount||!item.discount.std) return;
  if(item.discount.std.length<5) item.discount.std.push(0);
  lsSave(); updateCartUI();
}

function removeCartStdStep(pid){
  var item=cart.find(function(c){return c.id===pid;}); if(!item) return;
  if(!item.discount||!item.discount.std||item.discount.std.length<=1) return;
  item.discount.std.pop();
  lsSave(); updateCartUI();
}

function setCartItemCustomPrice(pid,val){
  var item=cart.find(function(c){return c.id===pid;}); if(!item) return;
  if(!item.discount) item.discount={type:'custom',customPrice:null,std:[]};
  var v=parseFloat(String(val).replace(',','.'));
  item.discount.customPrice=(isFinite(v)&&v>=0)?v:null;
  lsSave(); _updateCartItemRow(pid);
}

