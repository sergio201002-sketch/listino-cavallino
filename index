  else if(e.shape==='line') typeBadge=' <span style="font-size:9px;background:#888;color:#fff;border-radius:3px;padding:1px 5px;font-weight:700;vertical-align:middle">LINEARE</span>';
  h+='<div class="esp-name-display" id="espn-'+e.id+'" onclick="event.stopPropagation();espStartRename(\''+e.id+'\')">'+x(e.name)+typeBadge+'</div>';
