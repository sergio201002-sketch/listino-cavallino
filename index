// When series changes: rebuild size and finish based on that series
function cascadeFromSeries(){
  var ser = document.getElementById('sel-series').value;
  var pool = ser ? PRODUCTS.filter(function(p){ return p.s===ser; }) : PRODUCTS;
  var szSet={}, fiSet={};
  pool.forEach(function(p){ szSet[pSz(p)]=1; fiSet[p.f]=1; });
  var szArr = Object.keys(szSet).sort();
  var fiArr = Object.keys(fiSet).sort();
  rebuildSizeOpts(szArr);
  rebuildSelect('sel-finish', fiArr, 'Tutte le finiture');
}

// When size changes: further restrict finish options
function cascadeFromSize(){
  var ser = document.getElementById('sel-series').value;
  var siz = _szFilter;
  var pool = PRODUCTS.filter(function(p){
    if(ser && p.s!==ser) return false;
    if(siz && pSz(p)!==siz) return false;
    return true;
  });
  var fiSet={};
  pool.forEach(function(p){ fiSet[p.f]=1; });
  var fiArr = Object.keys(fiSet).sort();
  rebuildSelect('sel-finish', fiArr, 'Tutte le finiture');
}

function applyFilter(){
  var ser=document.getElementById('sel-series').value;
  var siz=_szFilter;
  var fin=document.getElementById('sel-finish').value;
  var typ=document.getElementById('sel-type').value;
  var txt=document.getElementById('s-text').value.toLowerCase().trim();
  filtered = PRODUCTS.filter(function(p){
    if(ser && p.s!==ser) return false;
    if(siz && pSz(p)!==siz) return false;
    if(fin && p.f!==fin) return false;
    if(typ && p.t!==typ) return false;
    if(txt){
      var search=(p.s+' '+p.c+' '+p.f+' '+p.z+' '+(p.v||'')+(p.zs?' S':'')).toLowerCase();
      if(search.indexOf(txt)<0) return false;
    }
    return true;
  });
  shown = 0;
  renderGrid();
}

// === GRID ===
function renderGrid(){
  var grid = document.getElementById('grid');
  var rbar = document.getElementById('rbar');
  rbar.style.display = filtered.length>0 ? 'flex' : 'none';
  document.getElementById('rbar-count').textContent = filtered.length + ' prodotti';
  if(!filtered.length){
    grid.innerHTML = '<div class="empty"><h3>&#128269; Nessun risultato</h3><p>Modifica i filtri</p></div>';
    return;
  }
  var slice = filtered.slice(0, PAGE);
  shown = slice.length;
  var html = '';
  var lastKey='';
  slice.forEach(function(p){
    var key=p.s+'|'+p.t+'|'+(p.v||'')+'|'+p.zs;
    if(key!==lastKey){ html+=makeHdr(p); lastKey=key; }
    html += makeCard(p);
  });
  if(filtered.length>shown){
    html += '<div class="load-more-wrap"><button class="btn-load" onclick="loadMore()">Carica altri ('+(filtered.length-shown)+' rimanenti)</button></div>';
  }
  grid.innerHTML = html;
}

function loadMore(){
  var grid = document.getElementById('grid');
  var lmw = grid.querySelector('.load-more-wrap');
  if(lmw) lmw.remove();
  var more = filtered.slice(shown, shown+PAGE);
  var html = '';
  var prev=shown>0?filtered[shown-1]:null;
  var lastKey=prev?(prev.s+'|'+prev.t+'|'+(prev.v||'')+'|'+prev.zs):'';
  more.forEach(function(p){
    var key=p.s+'|'+p.t+'|'+(p.v||'')+'|'+p.zs;
    if(key!==lastKey){ html+=makeHdr(p); lastKey=key; }
    html += makeCard(p);
  });
  shown += more.length;
  grid.insertAdjacentHTML('beforeend', html);
  if(filtered.length>shown){
    grid.insertAdjacentHTML('beforeend','<div class="load-more-wrap"><button class="btn-load" onclick="loadMore()">Carica altri ('+(filtered.length-shown)+' rimanenti)</button></div>');
  }
}

