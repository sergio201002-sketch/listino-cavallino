// Cart search
function cartSearch(q){
  var clearBtn=document.getElementById('cp-search-clear');
  var res=document.getElementById('cp-search-results');
  q=(q||'').trim();
  if(clearBtn) clearBtn.classList.toggle('visible',q.length>0);
  if(!q){ res.classList.remove('visible'); res.innerHTML=''; return; }
  var ql=q.toLowerCase();
  var scored=[];
  PRODUCTS.forEach(function(p){
    var cs=(p.s||'').toLowerCase(), cc=(p.c||'').toLowerCase(), cz=(p.z||'').toLowerCase(), cf=(p.f||'').toLowerCase(), ci=(p.id||'').toLowerCase();
    var score=-1;
    if(ci===ql) score=100;
    else if(ci.startsWith(ql)) score=90;
    else if(cs.startsWith(ql)) score=80;
    else if(cs.includes(ql)) score=60;
    else if(cc.includes(ql)) score=50;
    else if(cf.includes(ql)) score=30;
    else if(cz.includes(ql)) score=20;
    if(score>=0) scored.push({p:p,score:score});
  });
  scored.sort(function(a,b){return b.score-a.score;});
  var matches=scored.slice(0,20).map(function(x){return x.p;});
  if(!matches.length){ res.innerHTML='<div class="cp-sr-none">Nessun prodotto trovato</div>'; res.classList.add('visible'); return; }
  res.innerHTML=matches.map(function(p){
    var inCart=cart.find(function(c){return c.id===p.id;});
    var detail=[p.z,p.f,p.c].filter(Boolean).join(' · ');
    var mqField=inCart?'':'<div class="cp-sr-mq-wrap"><input class="cp-sr-mq" type="number" inputmode="decimal" id="csr-mq-'+p.id.replace(/[^a-z0-9]/g,'')+'" placeholder="mq" value="" onclick="event.stopPropagation()" onkeydown="if(event.key===\'Enter\'){cartSearchAdd(\''+p.id+'\',event)}" step="0.5" min="0.01"/><span class="cp-sr-mq-unit">m&#178;</span></div>';
    return '<div class="cp-sr-item'+(inCart?' already-in':'')+'" data-id="'+p.id+'">'
      +'<span class="cp-sr-code">'+x(p.s.substring(0,8))+'</span>'
      +'<div class="cp-sr-info"><div class="cp-sr-series">'+x(p.s)+'</div><div class="cp-sr-detail">'+x(detail)+'</div></div>'
      +'<span class="cp-sr-price">&#8364;'+( p.p!=null?p.p.toFixed(2):'—')+'</span>'
      +mqField
      +'<button class="cp-sr-add" onclick="cartSearchAdd(\''+p.id+'\',event)" title="'+(inCart?'Rimuovi':'Aggiungi')+'">'+(inCart?'&#10003;':'+')+'</button>'
      +'</div>';
  }).join('');
  res.classList.add('visible');
}

function cartSearchAdd(pid,e){
  e.stopPropagation();
  var inCart=cart.find(function(c){return c.id===pid;});
  if(inCart){
    removeCart(pid);
  } else {
    var mqInput=document.getElementById('csr-mq-'+pid.replace(/[^a-z0-9]/g,''));
    var mq=parseFloat(mqInput?mqInput.value:'')||1;
    var p=PRODUCTS.find(function(x){return x.id===pid;}); if(!p) return;
    var disc=(p.t==='speciale')?{type:'std',customPrice:null,std:[60]}:{type:'none',customPrice:null,std:[]};
    var ex=cart.find(function(c){return c.id===pid;});
    if(!ex) cart.push({id:p.id,s:p.s,c:p.c,z:p.z,f:p.f,p:p.p,m:p.m,mq:mq,discount:disc});
    lsSave(); updateBadge(); refreshCard(pid);
  }
  var inp=document.getElementById('cp-search-inp');
  if(inp) cartSearch(inp.value);
}

function cartSearchClear(){
