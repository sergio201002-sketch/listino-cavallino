// === CART ===

// Migra vecchi item con qty -> mq
(function _cartMigrate(){
  cart.forEach(function(item){
    if(item.qty !== undefined && item.mq === undefined){ item.mq = item.qty; delete item.qty; }
    if(!item.discount) item.discount = {type:'none', customPrice:null, std:[]};
  });
})();

function _cartItemUnit(item){
  var d = item.discount || {type:'none'};
  var base = item.p || 0;
  if(d.type === 'pct5')  return base * 0.95;
  if(d.type === 'pct10') return base * 0.90;
  if(d.type === 'custom' && typeof d.customPrice === 'number' && d.customPrice >= 0) return d.customPrice;
  if(d.type === 'std' && d.std && d.std.length){
    var pf = base;
    d.std.forEach(function(s){ var v=parseFloat(s); if(isFinite(v)&&v>0&&v<100) pf*=(1-v/100); });
    return pf;
  }
  return base;
}
function _cartItemTot(item){ return _cartItemUnit(item) * (parseFloat(item.mq)||0); }

function addCart(pid){
  var p = PRODUCTS.find(function(x){ return x.id===pid; });
  if(!p) return;
  var sid = 'mq_'+pid.replace(/[^a-z0-9]/g,'');
  var el = document.getElementById(sid);
  var mq = el ? (parseFloat(el.value)||1) : 1;
  var ex = cart.find(function(c){ return c.id===pid; });
  if(ex){ ex.mq=mq; } else {
    var disc = (p.t==='speciale') ? {type:'std',customPrice:null,std:[60]} : {type:'none',customPrice:null,std:[]};
    cart.push({id:p.id,s:p.s,c:p.c,z:p.z,f:p.f,p:p.p,m:p.m,mq:mq,discount:disc});
  }
  lsSave(); updateBadge();
  refreshCard(pid);
  openCart(); toast('Aggiunto al carrello');
}

