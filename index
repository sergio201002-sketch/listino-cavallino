function toast(msg){
  var el=document.getElementById('toast');
  el.textContent=msg; el.style.display='block';
  clearTimeout(el._t); el._t=setTimeout(function(){el.style.display='none';},2200);
}

// === PRODUCT MODAL ===
var mpCurId = null;

function openProduct(pid){
  var p = PRODUCTS.find(function(x){ return x.id===pid; });
  if(!p) return;
  mpCurId = pid;
  mpRender(p);
  openModal('m-product');
}

function mpRender(p){
  mpCurId = p.id;
  var family = PRODUCTS.filter(function(x){ return x.s===p.s; });

  // ALL unique colors in the series
  var allColors={}, allSizes={}, allVariants={};
  family.forEach(function(x){
    allColors[x.c] = allColors[x.c] || x;
    var sk=x.z+'|'+x.zs; allSizes[sk] = allSizes[sk] || x;
    var vk=x.v||'base'; allVariants[vk] = allVariants[vk] || x;
  });

  // Which colors are available for current size+variant selection?
  var availColors={};
  family.filter(function(x){ return x.z===p.z && x.zs===p.zs && (x.v||'')===(p.v||''); }).forEach(function(x){ availColors[x.c]=1; });
  // Which sizes are available for current color+variant selection?
  var availSizes={};
  family.filter(function(x){ return x.c===p.c && (x.v||'')===(p.v||''); }).forEach(function(x){ availSizes[x.z+'|'+x.zs]=1; });
  // Which variants available for current color+size?
  var availVariants={};
  family.filter(function(x){ return x.c===p.c && x.z===p.z && x.zs===p.zs; }).forEach(function(x){ availVariants[x.v||'base']=1; });

  // Header
  document.getElementById('mp-hdr').innerHTML =
    '<div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#1A6EFF;margin-bottom:3px">'+x(p.s)+'</div>'+
    '<div style="font-size:18px;font-weight:800;color:#111">'+x(p.c)+'</div>';

  // Colors — ALL series colors, gray out unavailable
  var colorList = Object.keys(allColors).sort();
  document.getElementById('mp-colors').innerHTML = colorList.map(function(c){
    var cp = allColors[c];
    var act = c===p.c ? ' active' : '';
    var avail = availColors[c] ? '' : ' style="opacity:.35"';
    return '<button class="pill'+act+'"'+avail+' onclick="mpSelectColor(\''+cp.id+'\')">'+x(c)+'</button>';
  }).join('');

  // Sizes — regular formats + collapsible Pezzi Speciali accordion
  var sizeList = Object.keys(allSizes).sort();
  var regularSizes = sizeList.filter(function(sk){ return allSizes[sk].t!=='speciale'; });
  var specialSizes = sizeList.filter(function(sk){ return allSizes[sk].t==='speciale'; });
  function szPill(sk){
    var sp = allSizes[sk];
    var act = (sp.z===p.z && sp.zs===p.zs) ? ' active' : '';
    var avail = availSizes[sk] ? '' : ' style="opacity:.35"';
    var lbl = sp.zs ? sp.z+' S' : sp.z;
    return '<button class="pill'+act+'"'+avail+' onclick="mpSelectSize(\''+sp.id+'\')">'+x(lbl)+'</button>';
  }
  var szHtml = regularSizes.map(szPill).join('');
  if(specialSizes.length){
    var spOpen = (p.t==='speciale') ? ' open' : '';
    szHtml += '<details class="sp-accordion"'+spOpen+'>'
      +'<summary class="sp-accordion-btn">Pezzi Speciali ('+specialSizes.length+')</summary>'
      +'<div class="sp-accordion-body">'+specialSizes.map(szPill).join('')+'</div>'
      +'</details>';
  }
  document.getElementById('mp-sizes').innerHTML = szHtml;

  // Variants (only if >1 in series)
  var vwrap = document.getElementById('mp-variants-wrap');
  var variantList = Object.keys(allVariants);
  if(variantList.length>1){
    document.getElementById('mp-variants').innerHTML = variantList.map(function(vk){
      var vp = allVariants[vk];
      var act = (vp.v||'base')===(p.v||'base') ? ' active' : '';
      var avail = availVariants[vk] ? '' : ' style="opacity:.35"';
      var lbl = _V_LABEL[vk] || (vk==='base'?'Standard':vk);
      var cls = vk==='c2o'?' c2o-pill':vk==='chevron'?' chev-pill':vk==='millerig'?' mill-pill':'';
      return '<button class="pill'+cls+act+'"'+avail+' onclick="mpSelectVariant(\''+vp.id+'\')">'+lbl+'</button>';
    }).join('');
    vwrap.style.display='';
  } else { vwrap.style.display='none'; }

  // Detail box
  var inc = cart.find(function(c){ return c.id===p.id; });
  var finTag = p.f ? '<span class="tag tag-fi">'+x(p.f)+'</span>' : '';
  var kTag = p.k ? '<span class="tag tag-th">'+x(p.k)+'</span>' : '';
  var _vtc={'c2o':'#1A6EFF','chevron':'#4A7C9E','millerig':'#4A7C9E','soft':'#7B5EA8','mr':'#3a7fc0','vc':'#2e7d6e','vc_mr':'#1a5c50','vc_c2o':'#0050CC','relievo':'#5C7A4F','intreccio':'#c0682b','intreccio_c2o':'#003399'};
  var vTag = (p.v&&_V_LABEL[p.v]) ? '<span class="tag" style="background:'+(_vtc[p.v]||'#666')+';color:#fff;font-weight:700">'+_V_LABEL[p.v]+'</span>' : '';
  document.getElementById('mp-detail').innerHTML =
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">'+
    '<div style="display:flex;gap:5px;flex-wrap:wrap">'+finTag+kTag+vTag+'</div>'+
    '<div style="text-align:right"><div style="font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#aaa">Prezzo netto</div>'+
    '<span style="font-size:22px;font-weight:800;color:#003399">&#8364; '+p.p.toFixed(2).replace('.',',')+'</span>'+
    ' <span style="font-size:13px;color:#bbb">/m&#178;</span></div></div>'+
    (p.m?'<div style="font-size:11px;color:#aaa">'+p.m+' m&#178;/pallet</div>':'')+
    (inc?'<div style="margin-top:8px;font-size:11px;color:#1A7A3C;font-weight:700">&#10003; Gi&#224; nel carrello ('+inc.qty+' m&#178;)</div>':'');

  document.getElementById('mp-qty').value = inc ? inc.qty : 1;
}

function mpSelectColor(pid){
  var chosen = PRODUCTS.find(function(x){ return x.id===pid; }); if(!chosen) return;
  var cur = PRODUCTS.find(function(x){ return x.id===mpCurId; });
  // Keep current size+variant if combination exists; otherwise take the first available
  var match = PRODUCTS.find(function(x){
    return x.s===chosen.s && x.c===chosen.c && x.z===(cur?cur.z:'') && x.zs===(cur?cur.zs:0) && (x.v||'')===(cur?cur.v||'':'');
  }) || PRODUCTS.find(function(x){ return x.s===chosen.s && x.c===chosen.c; });
  mpRender(match || chosen);
}
function mpSelectSize(pid){
  var chosen = PRODUCTS.find(function(x){ return x.id===pid; }); if(!chosen) return;
  var cur = PRODUCTS.find(function(x){ return x.id===mpCurId; });
  var match = PRODUCTS.find(function(x){
    return x.s===chosen.s && x.z===chosen.z && x.zs===chosen.zs && x.c===(cur?cur.c:'') && (x.v||'')===(cur?cur.v||'':'');
  }) || PRODUCTS.find(function(x){ return x.s===chosen.s && x.z===chosen.z && x.zs===chosen.zs; });
  mpRender(match || chosen);
}
function mpSelectVariant(pid){
  var chosen = PRODUCTS.find(function(x){ return x.id===pid; }); if(!chosen) return;
  var cur = PRODUCTS.find(function(x){ return x.id===mpCurId; });
  var match = PRODUCTS.find(function(x){
    return x.s===chosen.s && (x.v||'')===(chosen.v||'') && x.c===(cur?cur.c:'') && x.z===(cur?cur.z:'') && x.zs===(cur?cur.zs:0);
  }) || chosen;
  mpRender(match);
}
function mpAddToCart(){
  var p = PRODUCTS.find(function(x){ return x.id===mpCurId; });
  if(!p) return;
  var mq = parseFloat(document.getElementById('mp-qty').value)||1;
  var ex = cart.find(function(c){ return c.id===p.id; });
  if(ex){ ex.mq=mq; } else {
    var disc=(p.t==='speciale')?{type:'std',customPrice:null,std:[60]}:{type:'none',customPrice:null,std:[]};
    cart.push({id:p.id,s:p.s,c:p.c,z:p.z,f:p.f,p:p.p,m:p.m,mq:mq,discount:disc});
  }
  lsSave(); updateBadge();
  refreshCard(p.id);
  closeModal('m-product');
  openCart();
  toast('Aggiunto al carrello');
}

// === CSV EXPORT ===
function buildCsv(items, cliente, rif){
  var rows = [['Serie','Colore','Formato','Finitura','m²','Prezzo/m²','Sconto','Prezzo netto/m²','Totale €']];
  items.forEach(function(i){
    var finalUnit = _cartItemUnit ? _cartItemUnit(i) : (i.p||0);
    var mq = parseFloat(i.mq||i.qty)||0;
    var discLabel='';
    var d=i.discount||{type:'none'};
    if(d.type==='pct5') discLabel='-5%';
    else if(d.type==='pct10') discLabel='-10%';
    else if(d.type==='custom') discLabel='Netto';
    else if(d.type==='std'&&d.std&&d.std.length) discLabel=d.std.map(function(v){return '-'+v+'%';}).join(' ');
    rows.push([i.s||'',i.c||'',i.z||'',i.f||'',
      mq.toFixed(2),(i.p||0).toFixed(2),discLabel,finalUnit.toFixed(2),(finalUnit*mq).toFixed(2)]);
  });
  var total=items.reduce(function(s,i){var u=_cartItemUnit?_cartItemUnit(i):(i.p||0);return s+u*(parseFloat(i.mq||i.qty)||0);},0);
  rows.push(['','','','','','','','TOTALE',total.toFixed(2)]);
  if(cliente||rif) rows.unshift([cliente?'Cliente: '+cliente:'',rif?'Rif: '+rif:'','','','','','','','']);
  return '﻿'+rows.map(function(r){return r.map(function(c){return '"'+String(c||'').replace(/"/g,'""')+'"';}).join(';');}).join('\r\n');
}

function exportCartXls(){
  if(!cart.length){ toast('Carrello vuoto'); return; }
  var csv=buildCsv(cart,_cartClientId?(clients.find(function(c){return c.id===_cartClientId;})||{}).name||'':'',_cartRef||'');
  var blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  var link=document.createElement('a'); link.href=URL.createObjectURL(blob);
  link.download='ordine_'+(new Date().toLocaleDateString('it-IT').replace(/\//g,'-'))+'.csv'; link.click();
}

function exportOrderXls(oid){
  var o=orders.find(function(x){return x.id===oid;}); if(!o) return;
  var csv=buildCsv(o.items,o.cname,o.rif);
  var blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  var link=document.createElement('a'); link.href=URL.createObjectURL(blob);
  link.download='ordine'+(o.cname?'_'+o.cname.replace(/\s+/g,'_'):'')+'_'+(new Date(o.date).toLocaleDateString('it-IT').replace(/\//g,'-'))+'.csv'; link.click();
}

// === SETTINGS ===
function lsGetTypes(){ return lsGet('cc_esp_types') || []; }
function lsSaveTypes(t){ localStorage.setItem('cc_esp_types', JSON.stringify(t)); }

function openSettings(){
  document.getElementById('sett-overlay').classList.add('open');
  etRenderList();
}
function closeSettings(){
  document.getElementById('sett-overlay').classList.remove('open');
}
// === DESTINATARI ===
var _destList = (function(){ try{return JSON.parse(localStorage.getItem('cc_destinatari'))||['Davide'];}catch(e){return ['Davide'];} })();
function _destSave(){ try{localStorage.setItem('cc_destinatari',JSON.stringify(_destList));}catch(e){} }

function _destRenderSettings(){
  var el=document.getElementById('dest-list'); if(!el) return;
  if(!_destList.length){ el.innerHTML='<div style="font-size:12px;color:#aaa;text-align:center;padding:12px">Nessun destinatario</div>'; return; }
  el.innerHTML=_destList.map(function(name,i){
    return '<div style="display:flex;align-items:center;gap:8px;background:#F4F3EF;border:1px solid #E4E2DC;border-radius:7px;padding:8px 12px">'
      +'<span style="flex:1;font-size:13px;font-weight:600">'+x(name)+'</span>'
      +'<button class="mbtn-g" style="padding:4px 10px;font-size:11px" onclick="destRemove('+i+')">Rimuovi</button>'
      +'</div>';
  }).join('');
}

function _destRenderSelect(){
  var dl=document.getElementById('dest-datalist'); if(!dl) return;
  dl.innerHTML='';
  _destList.forEach(function(name){
    var o=document.createElement('option'); o.value=name; dl.appendChild(o);
  });
  var inp=document.getElementById('cp-recipient');
  if(inp) inp.value=_orderRecipient||'';
}

function destAdd(){
  var inp=document.getElementById('dest-new-name'); if(!inp) return;
  var name=inp.value.trim(); if(!name) return;
  if(_destList.indexOf(name)<0){ _destList.push(name); _destSave(); }
  inp.value=''; _destRenderSettings(); _destRenderSelect();
}

function destRemove(i){
  _destList.splice(i,1); _destSave(); _destRenderSettings(); _destRenderSelect();
}

// Inizializza select destinatari dopo DOMContentLoaded
(function(){ if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',_destRenderSelect); else _destRenderSelect(); })();

function settTab(btn, paneId){
  btn.closest('.sett-tabs').querySelectorAll('.sett-tab').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  btn.closest('.sett-box').querySelectorAll('.sett-body > div').forEach(function(p){ p.style.display='none'; });
  var pe = document.getElementById(paneId); if(pe) pe.style.display='';
  if(paneId==='sett-dest') _destRenderSettings();
}
function etShapeChange(){
  var rot = document.querySelector('input[name="et-shape"]:checked').value === 'rot';
  document.getElementById('et-perside-wrap').style.display = rot ? '' : 'none';
  document.getElementById('shape-line-lbl').classList.toggle('sel', !rot);
  document.getElementById('shape-rot-lbl').classList.toggle('sel', rot);
}
function etSave(){
  var name = document.getElementById('et-name').value.trim();
  if(!name){ toast('Inserisci il nome'); return; }
  var shape = document.querySelector('input[name="et-shape"]:checked').value;
  var total = parseInt(document.getElementById('et-total').value)||0;
  var perSide = shape==='rot' ? parseInt(document.getElementById('et-perside').value)||0 : 0;
  var types = lsGetTypes();
  types.push({id:'t'+Date.now(), name:name, shape:shape, total:total, perSide:perSide});
  lsSaveTypes(types);
  document.getElementById('et-name').value='';
  document.getElementById('et-total').value='';
  document.getElementById('et-perside').value='';
  etRenderList(); toast('Tipo creato');
}
function etDelete(tid){
  if(!confirm('Eliminare questo tipo?')) return;
  lsSaveTypes(lsGetTypes().filter(function(t){return t.id!==tid;}));
  etRenderList(); toast('Eliminato');
}
function etRenderList(){
  var types = lsGetTypes();
  var el = document.getElementById('et-list'); if(!el) return;
  if(!types.length){
    el.innerHTML='<div class="no-types">Nessun tipo creato.<br>Crea il primo con il modulo sopra.</div>';
    return;
  }
  el.innerHTML = types.map(function(t){
    var icon = t.shape==='rot' ? '&#127991;' : '&#128366;';
    var sub = (t.total||0)+' slot'+(t.shape==='rot'?' · '+t.perSide+'/lato':'')+(t.shape==='rot'?' · Girevole':' · Lineare');
    return '<div class="esp-type-card">'
      +'<div class="etc-icon">'+icon+'</div>'
      +'<div class="etc-info"><div class="etc-name">'+x(t.name)+'</div><div class="etc-sub">'+sub+'</div></div>'
      +'<button class="etc-del" onclick="etDelete(\''+t.id+'\')">&#128465;</button>'
      +'</div>';
  }).join('');
}

